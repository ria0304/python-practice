class Solution:
    def countAndSay(self, n: int) -> str:
        result = "1"
        
        for _ in range(1, n):
            next_term = ""
            count = 1
            current_char = result[0]
            
            for i in range(1, len(result)):
                if result[i] == current_char:
                    count += 1
                else:
                    next_term += str(count) + current_char
                    current_char = result[i]
                    count = 1
            
            next_term += str(count) + current_char
            result = next_term
        
        return result
