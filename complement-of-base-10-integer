class Solution(object):
    def bitwiseComplement(self, n):
        """
        :type n: int
        :rtype: int
        """
        if n == 0:
            return 1
        
        temp = n
        num_bits = 0
        while temp > 0:
            num_bits += 1
            temp //= 2
        
        mask = 0
        for i in range(num_bits):
            mask = mask * 2 + 1
        
        return mask - n
