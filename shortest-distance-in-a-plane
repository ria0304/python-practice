import pandas as pd
import numpy as np

def shortest_distance(point2_d: pd.DataFrame) -> pd.DataFrame:
    df = point2_d.merge(point2_d, how='cross', suffixes=('_1', '_2'))
    
    df = df[(df['x_1'] != df['x_2']) | (df['y_1'] != df['y_2'])]
    
    df['dist'] = np.sqrt((df['x_1'] - df['x_2'])**2 + (df['y_1'] - df['y_2'])**2)
    
    shortest = float(np.round(df['dist'].min(), 2))  
    
    return pd.DataFrame({'shortest': [shortest]})
